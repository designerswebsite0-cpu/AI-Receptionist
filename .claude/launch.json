{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api",
      "runtimeExecutable": "python",
      "runtimeArgs": [
        "-m", "uv", "run", "--directory", "apps/api",
        "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"
      ],
      "port": 8000
    },
    {
      "name": "dashboard",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dashboard:dev"],
      "port": 3000
    }
  ]
}
