# AI Receptionist Platform — Environment Variables
# Copy to .env and fill in real values. Never commit .env.
# Groups match requirements.md §13. "(Phase N)" vars are not needed until that phase.

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
APP_ENV=development
APP_NAME=ai-receptionist-api
API_HOST=0.0.0.0
API_PORT=8000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------------
# Database (Supabase Postgres) — required for Phase 1
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_receptionist
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/ai_receptionist

# ---------------------------------------------------------------------------
# Supabase — required for Phase 1 (Auth, RLS, Storage, Realtime)
# ---------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=changeme
SUPABASE_SERVICE_ROLE_KEY=changeme
SUPABASE_JWT_AUD=authenticated
# JWKS is fetched from {SUPABASE_URL}/auth/v1/.well-known/jwks.json — no separate secret needed.

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
AUTH_LOGIN_RATE_LIMIT_PER_MINUTE=10
SESSION_COOKIE_SECURE=true

# ---------------------------------------------------------------------------
# Redis (Upstash) — required starting Phase 3
# ---------------------------------------------------------------------------
REDIS_URL=

# ---------------------------------------------------------------------------
# AI — required starting Phase 4
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
# gpt-4o-mini is the recommended default for a guest-chat receptionist: a
# reasoning-tier model (gpt-5, o-series) is both slower and far more
# expensive per message for grounded Q&A that doesn't need deep reasoning.
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
GROQ_API_KEY=
# Caps the model's reply length — keeps responses short/chat-like and
# directly bounds both cost and latency per turn.
ORCHESTRATION_MAX_RESPONSE_TOKENS=220

# ---------------------------------------------------------------------------
# Knowledge Intelligence Engine — required starting Phase 3
# ---------------------------------------------------------------------------
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
# Fail-closed by default: if ClamAV is unreachable in production, activation
# is blocked rather than silently treating an unscanned file as safe.
CLAMAV_REQUIRED_IN_PRODUCTION=true
# Override only if tesseract isn't on PATH.
TESSERACT_CMD=
KNOWLEDGE_STORAGE_BUCKET=knowledge-documents

# ---------------------------------------------------------------------------
# Website Chat Channel — required starting Phase 5. Public, anonymous-guest
# surface; limits are read from here rather than hard-coded so ops can tune
# them per deployment.
# ---------------------------------------------------------------------------
WEBCHAT_ENABLED=true
WEBCHAT_ALLOWED_ORIGINS=http://localhost:3000
WEBCHAT_SESSION_TTL_SECONDS=604800
WEBCHAT_MAX_MESSAGE_LENGTH=2000
WEBCHAT_RATE_LIMIT_PER_MINUTE=8
WEBCHAT_CONVERSATION_LIMIT_PER_IP_PER_HOUR=5
WEBCHAT_MESSAGE_LIMIT_PER_IP_PER_MINUTE=20

# ---------------------------------------------------------------------------
# WhatsApp Cloud API — required starting Phase 6
# ---------------------------------------------------------------------------
WHATSAPP_APP_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# ---------------------------------------------------------------------------
# Voice — Phase 9 (Global Voice Call System, inbound only). No production
# credentials exist yet; every value below is optional and the app boots
# fine with all of them blank — see docs/phase-9/ENVIRONMENT.md.
# ---------------------------------------------------------------------------
VOICE_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Distinct from TWILIO_FROM_NUMBER below (Phase 7 SMS) — voice and SMS may
# end up on different Twilio numbers.
TWILIO_PHONE_NUMBER=

LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

DEEPGRAM_API_KEY=

ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Reuses GROQ_API_KEY/OPENAI_API_KEY above — voice's provider order is
# Groq primary / OpenAI 4o-mini fallback, the reverse of text channels.

# ---------------------------------------------------------------------------
# Room Booking SMS confirmation (Phase 7) — TWILIO_ACCOUNT_SID/AUTH_TOKEN
# are shared with Voice above; this is a separate sending number since
# voice and SMS may end up on different Twilio numbers.
# ---------------------------------------------------------------------------
TWILIO_FROM_NUMBER=
BOOKING_MAX_ADVANCE_DAYS=183

# ---------------------------------------------------------------------------
# Payments (Phase 7 — no gateway account yet, staff-recorded placeholder only)
# ---------------------------------------------------------------------------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Integrations (Phase 7)
# ---------------------------------------------------------------------------
RESEND_API_KEY=
N8N_WEBHOOK_BASE_URL=
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Monitoring
# ---------------------------------------------------------------------------
SENTRY_DSN=
BETTER_STACK_TOKEN=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ---------------------------------------------------------------------------
# Dashboard (Next.js) — only NEXT_PUBLIC_* is browser-exposed
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=changeme

# ---------------------------------------------------------------------------
# Website (Next.js, apps/website) — Phase 5. Only NEXT_PUBLIC_* is
# browser-exposed; the website's own server (Route Handlers) is what talks
# to the FastAPI backend server-to-server, so no AI/database credentials
# are ever needed here.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WEBCHAT_ENABLED=true
