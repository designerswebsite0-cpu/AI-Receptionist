# AI Receptionist Platform — Environment Variables
# Copy to .env and fill in real values. Never commit .env.
# Groups match requirements.md §13. "(Phase N)" vars are not needed until that phase.

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
APP_ENV=development
APP_NAME=ai-receptionist-api
API_HOST=0.0.0.0
API_PORT=8000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------------
# Database (Supabase Postgres) — required for Phase 1
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_receptionist
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/ai_receptionist

# ---------------------------------------------------------------------------
# Supabase — required for Phase 1 (Auth, RLS, Storage, Realtime)
# ---------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=changeme
SUPABASE_SERVICE_ROLE_KEY=changeme
SUPABASE_JWT_AUD=authenticated
# JWKS is fetched from {SUPABASE_URL}/auth/v1/.well-known/jwks.json — no separate secret needed.

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
AUTH_LOGIN_RATE_LIMIT_PER_MINUTE=10
SESSION_COOKIE_SECURE=true

# ---------------------------------------------------------------------------
# Redis (Upstash) — required starting Phase 3
# ---------------------------------------------------------------------------
REDIS_URL=

# ---------------------------------------------------------------------------
# AI — required starting Phase 4
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
GROQ_API_KEY=

# ---------------------------------------------------------------------------
# Knowledge Intelligence Engine — required starting Phase 3
# ---------------------------------------------------------------------------
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
# Fail-closed by default: if ClamAV is unreachable in production, activation
# is blocked rather than silently treating an unscanned file as safe.
CLAMAV_REQUIRED_IN_PRODUCTION=true
# Override only if tesseract isn't on PATH.
TESSERACT_CMD=
KNOWLEDGE_STORAGE_BUCKET=knowledge-documents

# ---------------------------------------------------------------------------
# WhatsApp Cloud API — required starting Phase 6
# ---------------------------------------------------------------------------
WHATSAPP_APP_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# ---------------------------------------------------------------------------
# Voice (future — Phase 9)
# ---------------------------------------------------------------------------
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# ---------------------------------------------------------------------------
# Payments (Phase 7)
# ---------------------------------------------------------------------------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Integrations (Phase 7)
# ---------------------------------------------------------------------------
RESEND_API_KEY=
N8N_WEBHOOK_BASE_URL=
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Monitoring
# ---------------------------------------------------------------------------
SENTRY_DSN=
BETTER_STACK_TOKEN=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ---------------------------------------------------------------------------
# Dashboard (Next.js) — only NEXT_PUBLIC_* is browser-exposed
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=changeme
